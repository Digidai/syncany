{
  "name": "raltic",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "pnpm --filter @raltic/web dev",
    "dev:bridge": "pnpm --filter @raltic/bridge dev",
    "db:generate": "pnpm --filter @raltic/db generate",
    "db:push": "pnpm --filter @raltic/db push",
    "test": "pnpm -r test --run",
    "test:migrations": "node scripts/check-test-migrations.mjs",
    "e2e": "playwright test",
    "e2e:visual": "E2E_RUN_VISUAL=1 playwright test e2e/visual-snapshots.spec.ts",
    "e2e:update-visual": "E2E_RUN_VISUAL=1 playwright test e2e/visual-snapshots.spec.ts --update-snapshots",
    "e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@slock-ai/daemon": "^0.40.2"
  },
  "pnpm": {
    "overrides": {
      "react-notion-avatar>@types/react": "^19",
      "react-notion-avatar>@types/react-dom": "^19",
      "better-auth": "1.6.9",
      "@better-auth/core": "1.6.9"
    }
  }
}
