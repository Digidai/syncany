{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "raltic-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-23",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "48d9ccaf5ee7914c803b5d0656462848",

  "routes": [
    { "pattern": "api.raltic.com", "custom_domain": true }
  ],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "raltic-staging",
      "database_id": "b1c3ee93-69a6-45a3-bfa9-56d37e8971f2",
      "migrations_dir": "../../packages/db/migrations"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "RATE_LIMITS",
      "id": "0220a0370443459da81d3c834702e9cd"
    }
  ],

  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "raltic-uploads"
    },
    {
      "binding": "BACKUPS",
      "bucket_name": "raltic-backups"
    }
  ],

  // Cron triggers — handlers in src/scheduled.ts dispatch on event.cron.
  // 03:00 UTC daily: D1 dump → R2 raltic-backups + prune > 30 days.
  // Cron schedule:
  //   0 3 * * *      — daily 03:00 UTC backup
  //   */5 * * * *    — Vectorize backfill (catches messages missed by
  //                    inline DO indexing — see scheduled.ts)
  "triggers": {
    "crons": ["0 3 * * *", "*/5 * * * *"]
  },

  "durable_objects": {
    "bindings": [
      { "name": "CHAT_ROOM",    "class_name": "ChatRoom" },
      { "name": "USER_GATEWAY", "class_name": "UserGateway" },
      // RalticAgent — one DO instance per Agent record (P0 W2).
      // Class implements CF Agents SDK Agent base; per-agent state,
      // history, todoList, sandbox container id live in DO storage.
      { "name": "RALTIC_AGENT", "class_name": "RalticAgent" },
      // P1 W4: per-Agent sandbox container wrapper. CF builds the image
      // from packages/sandbox-image/Dockerfile at deploy time (Docker
      // CLI / OrbStack must be running locally), then SANDBOX.get(
      // idFromName(containerId)).fetch(...) routes through this DO,
      // wakes the container if asleep, proxies to sandbox-daemon :8080.
      { "name": "SANDBOX",      "class_name": "SandboxContainer" }
    ]
  },

  // P1 W4 — container image used by SandboxContainer DO. We push the image
  // out-of-band with `wrangler containers push raltic-sandbox:<tag>` (built
  // for linux/amd64) and reference it here by `image_uri`. Bumping the tag
  // is what rolls forward — wrangler does NOT rebuild on deploy.
  //   Build:  docker build --platform linux/amd64 -f packages/sandbox-image/Dockerfile -t raltic-sandbox:<tag> .
  //   Push:   npx wrangler containers push raltic-sandbox:<tag>
  //   Bump:   update image_uri tag below and `wrangler deploy`.
  "containers": [
    {
      "class_name": "SandboxContainer",
      "image": "registry.cloudflare.com/48d9ccaf5ee7914c803b5d0656462848/raltic-sandbox:0.1.0",
      "max_instances": 1000,
      "instance_type": "basic"
    }
  ],

  // AI binding (Workers AI for embeddings, Llama for local inference).
  "ai": {
    "binding": "AI"
  },

  // Vectorize index for semantic message search.
  // P3: switched from raltic-messages-prod (768-d bge-base-en-v1.5) to
  // raltic-messages-v2 (1024-d bge-m3, multilingual including CJK).
  // Metadata indexes on channelId/senderType/ts so search_messages
  // can pre-filter (cheaper than post-filter SQL). Recreate with:
  //   wrangler vectorize create raltic-messages-v2 --dimensions 1024 --metric cosine
  //   wrangler vectorize create-metadata-index raltic-messages-v2 --property-name channelId --type string
  //   wrangler vectorize create-metadata-index raltic-messages-v2 --property-name senderType --type string
  //   wrangler vectorize create-metadata-index raltic-messages-v2 --property-name ts --type number
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "raltic-messages-v2"
    }
  ],

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChatRoom", "UserGateway"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["RalticAgent"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["SandboxContainer"]
    }
  ],

  "vars": {
    "WEB_ORIGIN": "https://raltic.com",
    "GOOGLE_CLIENT_ID": "354332228451-j9k7m3js0tlgt2rajfiov9cd505votbl.apps.googleusercontent.com",
    // Used by the daily backup cron in src/scheduled.ts. Not secrets —
    // account id is in every URL, database id is in this same file.
    // CF_API_TOKEN is a secret and must be set via `wrangler secret put`.
    "CF_ACCOUNT_ID": "48d9ccaf5ee7914c803b5d0656462848",
    "D1_DATABASE_ID": "b1c3ee93-69a6-45a3-bfa9-56d37e8971f2",
    // AI Gateway endpoint for RalticAgent. Create the gateway in CF
    // dashboard (AI → AI Gateway → New gateway, id "raltic-prod"), then
    // adjust this URL. Worker fails fast at boot if missing.
    // OpenAI-compatible LLM router. easyrouter.io speaks /v1/chat/completions
    // and maps model name → upstream provider (Anthropic / OpenAI / Google).
    // Later: switch to a CF AI Gateway universal endpoint that proxies to
    // easyrouter (gives us caching + per-tenant metrics on top of router).
    "AI_GATEWAY_BASE": "https://easyrouter.io/v1"
    // Secrets to set via `wrangler secret put`:
    //   LLM_API_KEY          — router platform key (easyrouter sk-...)
    //   AI_GATEWAY_TOKEN     — only when AI_GATEWAY_BASE is a CF gateway URL
  },

  "observability": {
    "enabled": true
  }
}
