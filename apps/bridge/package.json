{
  "name": "@raltic/bridge",
  "version": "0.3.4",
  "description": "Raltic local bridge — connects your Claude Code agents to the Raltic web app",
  "homepage": "https://github.com/Digidai/raltic",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digidai/raltic.git"
  },
  "type": "module",
  "bin": {
    "raltic-bridge": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "postbuild": "chmod +x dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "raltic",
    "claude",
    "claude-code",
    "ai",
    "agent",
    "bridge"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@raltic/cli": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@raltic/cli": {
      "optional": false
    }
  },
  "dependencies": {
    "@raltic/cli": "workspace:^",
    "@openai/codex-sdk": "0.130.0"
  },
  "devDependencies": {
    "@raltic/bridge-core": "workspace:*",
    "@raltic/agent-runtime": "workspace:*",
    "@raltic/protocol": "workspace:*",
    "@types/node": "^20.19.39",
    "esbuild": "^0.27.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
