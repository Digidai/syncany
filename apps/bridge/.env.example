# Cowork Bridge — local dev configuration
#
# For normal use, you don't need any of this — just run:
#   npx @cowork/bridge --api-key <your-machine-api-key>
#
# These env vars are only used when running the bridge from source (pnpm dev:bridge)
# or when self-hosting the Cowork server. Everything except COWORK_AGENTS_DIR can be
# overridden by the corresponding CLI flag.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
COWORK_USER_ID=your-supabase-user-uuid
COWORK_AGENTS_DIR=~/.cowork/agents
