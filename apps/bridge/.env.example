# Raltic Bridge — local dev configuration
#
# For normal use, you don't need any of this — just run:
#   npx -y @raltic/bridge --api-key <your-machine-api-key> --server-url https://api.raltic.com
#
# These env vars are only used when running the bridge from source (pnpm dev:bridge)
# or when self-hosting Raltic. Everything except RALTIC_AGENTS_DIR can be
# overridden by the corresponding CLI flag.

RALTIC_SERVER_URL=https://api.raltic.com
RALTIC_API_KEY=ck_your-machine-api-key
# Or use multiple workspace keys:
# RALTIC_API_KEYS=ck_workspace_a,ck_workspace_b
RALTIC_AGENTS_DIR=~/.raltic/agents
